---
// AInews · Zettel 列表卡片，从 zettel/index.astro 抽出
// 首屏 SSR 与 zettel/more.astro 懒加载片段共用同一份组件
import AIBadge from './AIBadge.astro'

interface Props {
  id: string
  title: string | null
  gist: string | null
  topicSlug: string | null
  docDate: string | null
  backlinkCount: number
}
const { id, title, gist, topicSlug, docDate, backlinkCount } = Astro.props

// 兜底：老数据缺 frontmatter title 时从 slug 派生一个近似英文标题
function deriveTitle(slug: string): string {
  const m = slug.match(/^\d{12}-(.+)$/)
  if (!m) return slug
  return m[1].split('-').map((w) => w[0]?.toUpperCase() + w.slice(1)).join(' ')
}
const displayTitle = title ?? deriveTitle(id)
---

<article class="zettel-card">
  <div class="zettel-card-top">
    <AIBadge />
    <a href={`/topics/${topicSlug}/`} class="lumina-chip zettel-card-chip">
      #{topicSlug}
    </a>
  </div>
  <h3 class="zettel-card-title">
    <a href={`/zettel/${id}/`} class="zettel-card-link">{displayTitle}</a>
  </h3>
  <p class="zettel-card-excerpt">{gist ?? ''}</p>
  <div class="zettel-card-footer">
    <span>{docDate ?? ''}</span>
    {backlinkCount > 0 && (
      <span class="zettel-card-backlink-count">
        <span class="material-symbols-outlined" style="font-size: 0.85rem;">arrow_upward</span>
        {backlinkCount}
      </span>
    )}
  </div>
</article>

<style>
  .zettel-card {
    display: block;
    position: relative;
    break-inside: avoid;
    margin-bottom: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface-container-lowest);
    border: 1px solid var(--color-lightgray);
    border-left: 3px solid var(--ai-accent);
    border-radius: var(--radius-xl);
    color: var(--color-dark);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .zettel-card:has(.zettel-card-link:hover) {
    box-shadow: var(--shadow-card-hover);
    border-left-color: var(--ai-accent-dark);
  }
  .zettel-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  /* topic chip 是独立可点击链接，需高于 stretched-link 伪元素 */
  .zettel-card-chip {
    position: relative;
    z-index: 1;
  }
  .zettel-card-title {
    font-family: var(--font-header);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0 0 0.25rem;
  }
  /* stretched-link：标题链接用 ::after 撑满整卡，使全卡可点击且不违反 <a> 嵌套规范 */
  .zettel-card-link {
    color: inherit;
    text-decoration: none;
  }
  .zettel-card-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .zettel-card-excerpt {
    margin: 0 0 1rem;
    color: var(--color-darkgray);
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .zettel-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-header);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--color-gray);
    text-transform: uppercase;
  }
  .zettel-card-backlink-count {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-secondary);
  }
</style>
