---
// AInews · AIBadge · Emerald pill 标记 AI 生成/翻译内容
interface Props {
  label?: string // 默认 "AI 生成"
  variant?: 'default' | 'translation' // translation = "AI 翻译"
}
const { label, variant = 'default' } = Astro.props
const text = label ?? (variant === 'translation' ? 'AI 翻译' : 'AI 生成')
---

<span class="lumina-ai-badge">
  <span class="material-symbols-outlined lumina-ai-badge-icon" aria-hidden="true">auto_awesome</span>
  <span>{text}</span>
</span>

<style>
  .lumina-ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.65rem 0.25rem 0.5rem;
    background: var(--ai-accent-light);
    color: var(--ai-accent-on);
    border-radius: var(--radius-full);
    font-family: var(--font-header);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .lumina-ai-badge-icon {
    font-size: 0.95rem;
    color: var(--ai-accent-container-on);
    font-variation-settings: 'FILL' 1;
  }
</style>
