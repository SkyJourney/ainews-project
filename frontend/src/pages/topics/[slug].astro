---
// AInews · Topic 详情页 /topics/{slug}/
// Hero + entry_total + 时间线聚合内容 + 反查相关 Zettel/Original
//
// 不再走 getLiveEntry/postgres-loader.ts 的整篇渲染：Topic 是唯一无限期持续累积
// 内容的文档类型（每天追加一个日期区块），实测把整篇 body_md 一次性 markdown→HTML
// 渲染，耗时随历史长度超线性增长（46KB/9 区块 56ms，合成 20 倍规模 1.7s）。这里改成
// 只渲染最近几个区块，其余的区块通过 more.astro 片段端点按需渲染（见 topic-sections.ts）。
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import LuminaBacklinks from '../../components/enhance/LuminaBacklinks.astro'
import { fetchDocumentById, fetchBacklinks } from '../../lib/db'
import { renderMarkdownToHtml } from '../../lib/markdown-render'
import { splitTopicSections } from '../../lib/topic-sections'
import { TOPIC_DETAIL_SECTIONS_PER_BATCH } from '../../lib/pagination'

const { slug } = Astro.params
const row = await fetchDocumentById(slug!)
if (!row || row.doc_type !== 'topic') {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

const sections = splitTopicSections(row.body_md)
const initialSections = sections.slice(0, TOPIC_DETAIL_SECTIONS_PER_BATCH)
const hasMoreSections = sections.length > initialSections.length

const initialHtml = await renderMarkdownToHtml(
  initialSections.map((s) => s.markdown).join('\n\n'),
  `${row.content_hash}:0:${initialSections.length}`,
)

const backlinkRows = await fetchBacklinks(row.id)
const backlinks = backlinkRows.map((r) => ({ fromId: r.from_id, docType: r.doc_type, title: r.title }))

const articleCount = (row.frontmatter.article_count as number | null) ?? 0
const eyebrow = `${articleCount} 条 · 更新 ${row.doc_date ?? ''}`
---

<BaseLayout
  title={`#${row.id} · 主题聚合`}
  description={`AI 主题 ${row.id} · ${articleCount} 条时间线`}
>
  <article class="topic-detail">
    <HeroSection
      eyebrow={eyebrow}
      title={`#${row.id}`}
      subtitle="按日期倒序聚合该主题的所有条目"
    />

    <div
      class="topic-detail-body lumina-reading-well"
      data-infinite-list
      data-endpoint={`/topics/${row.id}/more`}
      data-page="2"
      data-mode="flat"
    >
      <div set:html={initialHtml} />
      {hasMoreSections && <div data-scroll-sentinel></div>}
    </div>

    <LuminaBacklinks backlinks={backlinks} />
  </article>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .topic-detail { padding-block: 1rem 4rem; }
  .topic-detail-body {
    font-size: 1rem;
    line-height: 1.75;
    margin-top: 2rem;
  }
</style>
