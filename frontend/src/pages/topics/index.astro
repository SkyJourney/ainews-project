---
// AInews · Topics 列表 · 3-col grid
// Stage 2/3：改走轻量分页查询（topic 数量天然有上限，实际很少会翻页，但沿用同一套
// 机制不特殊处理）
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import TopicCard from '../../components/cards/TopicCard.astro'
import { fetchDocumentSummariesByType, fetchMaxDocDate } from '../../lib/db'
import { TOPICS_PAGE_SIZE } from '../../lib/pagination'

const [{ rows, total }, maxUpdated] = await Promise.all([
  fetchDocumentSummariesByType('topic', { limit: TOPICS_PAGE_SIZE, offset: 0 }),
  fetchMaxDocDate('topic'),
])
const eyebrow = `${total} 主题 · 更新至 ${maxUpdated ?? '—'}`
const hasMore = rows.length < total
---

<BaseLayout
  title="Topics · 主题聚合"
  description="AI 主题按类别聚合 · 每主题包含累计条目 + 时间线"
>
  <HeroSection
    eyebrow={eyebrow}
    title="主题聚合"
    subtitle="追踪 AI 各领域的持续动态，看一个主题如何随时间演进"
  />

  <div class="topics-grid" data-infinite-list data-endpoint="/topics/more" data-page="2" data-mode="flat">
    {rows.map((row) => (
      <TopicCard
        slug={row.id}
        articleCount={(row.frontmatter.article_count as number | null) ?? null}
        lastUpdatedDate={row.doc_date}
      />
    ))}
    {hasMore && <div data-scroll-sentinel></div>}
  </div>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
</style>
