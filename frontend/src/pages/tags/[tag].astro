---
// AInews · 单个标签下的全部文档 /tags/{tag}/（M6 新增）
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import IntelligenceCard from '../../components/cards/IntelligenceCard.astro'
import { fetchDocumentsByTag } from '../../lib/db'
import { docHref, DOC_TYPE_LABEL, type DocType } from '../../lib/doc-type'

// 标签页不在导航 6 个列表页范围内，暂不接入滑动懒加载；用较大的单页上限
// 先解决"分页查询不含 body_md"这一半（性能），交互仍是一次性渲染。
const TAG_PAGE_SIZE = 60

const { tag } = Astro.params
const { rows: docs, total } = await fetchDocumentsByTag(decodeURIComponent(tag!), { limit: TAG_PAGE_SIZE, offset: 0 })

if (docs.length === 0) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}
---

<BaseLayout title={`#${tag} · 标签`} description={`AInews 标签 #${tag} 下的全部内容，共 ${total} 条`}>
  <HeroSection eyebrow={`标签 · ${total} 条`} title={`#${tag}`} subtitle="按日期倒序" />

  <div class="tag-doc-list">
    {docs.map((d) => (
      <IntelligenceCard
        href={docHref(d.doc_type, d.id)}
        eyebrow={DOC_TYPE_LABEL[d.doc_type as DocType] ?? d.doc_type}
        title={d.title ?? d.id}
        metaLine={d.doc_date ?? ''}
      />
    ))}
  </div>

  {total > docs.length && (
    <p class="tag-list-truncated-notice">
      仅显示最新 {docs.length} 条（共 {total} 条），标签页暂不支持翻页
    </p>
  )}
</BaseLayout>

<style>
  .tag-doc-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .tag-list-truncated-notice {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-darkgray);
  }
</style>
