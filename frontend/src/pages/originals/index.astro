---
// AInews · Originals 列表 · 3-col magazine 布局
// Stage 2/3：不再经过 postgres-loader.ts 的全文渲染+N+1（268+ 篇每次全量渲染是真实的
// SSR 性能瓶颈），改走轻量分页查询；首屏只查第 1 页，其余靠滑动懒加载（见 more.astro）
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import OriginalCard from '../../components/cards/OriginalCard.astro'
import { fetchDocumentSummariesByType, fetchDistinctFrontmatterFieldCount } from '../../lib/db'
import { ORIGINALS_PAGE_SIZE } from '../../lib/pagination'

const [{ rows, total }, sourceCount] = await Promise.all([
  fetchDocumentSummariesByType('original', { limit: ORIGINALS_PAGE_SIZE, offset: 0 }),
  fetchDistinctFrontmatterFieldCount('original', 'source_name'),
])
const eyebrow = `${total} 篇 · ${sourceCount} 源`
const hasMore = rows.length < total
---

<BaseLayout
  title="Sources · 原文归档"
  description="AInews 原文全文离线归档 · 含 AI 中文翻译"
>
  <HeroSection
    eyebrow={eyebrow}
    title="原文归档"
    subtitle="原文全文与中文翻译完整收录，即使原始链接失效，内容依然可读"
  />

  <div class="originals-magazine" data-infinite-list data-endpoint="/originals/more" data-page="2" data-mode="flat">
    {rows.map((row) => (
      <OriginalCard
        id={row.id}
        title={row.title}
        docDate={row.doc_date}
        wordCount={(row.frontmatter.word_count as number | null) ?? null}
        sourceName={row.frontmatter.source_name as string | null}
      />
    ))}
    {hasMore && <div data-scroll-sentinel></div>}
  </div>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .originals-magazine {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
</style>
