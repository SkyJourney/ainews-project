---
// AInews · Deep Dives 列表（M10，请求时查 Postgres doc_type='deep_dive'）
// 每周一 09:00 Asia/Shanghai 由独立 Temporal Schedule 产出一篇，量级参照 Daily
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import IntelligenceCard from '../../components/cards/IntelligenceCard.astro'
import { fetchDocumentSummariesByType, fetchMaxDocDate } from '../../lib/db'
import { DEEP_DIVES_PAGE_SIZE } from '../../lib/pagination'

const [{ rows, total }, maxUpdated] = await Promise.all([
  fetchDocumentSummariesByType('deep_dive', { limit: DEEP_DIVES_PAGE_SIZE, offset: 0 }),
  fetchMaxDocDate('deep_dive'),
])
const eyebrow = `${total} 期 · 更新至 ${maxUpdated ?? '—'}`
const hasMore = rows.length < total
---

<BaseLayout
  title="Deep Dives · 深度报告"
  description="AInews 深度报告 · 每周跨话题趋势聚合 + 每月专题深挖，附带整体叙事导语"
>
  <HeroSection
    eyebrow={eyebrow}
    title="深度报告"
    subtitle="深度周报：每周聚合本周热门话题趋势；专题月报：固定话题按月纵向深挖"
  />

  <div class="deep-dives-list" data-infinite-list data-endpoint="/deep-dives/more" data-page="2" data-mode="flat">
    {rows.map((row) => {
      const windowStart = row.frontmatter.window_start as string | undefined
      const windowEnd = row.frontmatter.window_end as string | undefined
      const entryCount = (row.frontmatter.entry_count as number | null) ?? 0
      // topic_slug 有值 = 专题月报（M11），无值 = 深度周报（M10）——两种形态复用同一个
      // doc_type='deep_dive'，靠这个字段区分，不新增独立类型（见 M11 设计决策）
      const topicSlug = row.frontmatter.topic_slug as string | undefined
      const rangeLabel = windowStart && windowEnd ? `${windowStart} ~ ${windowEnd}` : row.doc_date ?? ''
      const eyebrow = topicSlug ? `专题月报 · ${rangeLabel}` : `深度周报 · ${rangeLabel}`
      const metaLine = topicSlug
        ? `${entryCount} 条原文 · ${(row.frontmatter.zettel_count as number | null) ?? 0} 条笔记引用`
        : `${entryCount} 条原文 · ${((row.frontmatter.trending_topics as unknown[] | null) ?? []).length} 个热门话题`
      return (
        <IntelligenceCard
          href={`/deep-dives/${row.id}/`}
          eyebrow={eyebrow}
          title={row.title ?? row.id}
          metaLine={metaLine}
          ai={true}
        />
      )
    })}
    {hasMore && <div data-scroll-sentinel></div>}
  </div>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .deep-dives-list {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }
</style>
