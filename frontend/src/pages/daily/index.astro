---
// AInews · Daily 列表 · Timeline 布局
// 左 sticky 月份 · 右每日 IntelligenceCard
// Stage 2/3：改走轻量分页查询；按月分组的懒加载片段用 data-month/data-month-entries
// 标记，infinite-scroll.js 的 grouped 模式据此判断"新批次第一个月是否要并入已渲染的
// 最后一个月分组"，避免同一个月被分页切断后重复出现两次月份标题
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import DailyMonthGroup from '../../components/cards/DailyMonthGroup.astro'
import { fetchDocumentSummariesByType, fetchDailyDistinctTopicsCount } from '../../lib/db'
import { DAILY_PAGE_SIZE } from '../../lib/pagination'
import { groupByMonth } from '../../lib/daily-grouping'

const [{ rows, total }, topicCount] = await Promise.all([
  fetchDocumentSummariesByType('daily', { limit: DAILY_PAGE_SIZE, offset: 0 }),
  fetchDailyDistinctTopicsCount(),
])
const groups = groupByMonth(rows)
const eyebrow = `${total} 篇 · ${topicCount} 主题`
const hasMore = rows.length < total
---

<BaseLayout
  title="Daily · 每日简报"
  description="AInews 每日 AI 资讯简报 · 按日期倒序时间线"
>
  <HeroSection
    eyebrow={eyebrow}
    title="每日简报"
    subtitle="每天一份 AI 行业速览，重要发布、研究进展与行业信号一目了然"
  />

  <div class="daily-timeline" data-infinite-list data-endpoint="/daily/more" data-page="2" data-mode="grouped">
    {groups.map((g) => <DailyMonthGroup group={g} />)}
    {hasMore && <div data-scroll-sentinel></div>}
  </div>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .daily-timeline {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 2rem;
  }
</style>
