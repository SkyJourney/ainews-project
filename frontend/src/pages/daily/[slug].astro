---
// AInews · Daily 详情页 /daily/{YYYY-MM-DD}/
export const prerender = false

import { getLiveEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import DailyPageContent from '../../components/content/DailyPageContent.astro'

const { slug } = Astro.params
const { entry, error } = await getLiveEntry('daily', slug!)
if (error || !entry) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}
const title = `AI 资讯日报 ${entry.id}`
const stats = (entry.data.stats as Record<string, number>) ?? {}
const topics = (entry.data.topics as string[]) ?? []
---

<BaseLayout
  title={title}
  description={`AInews ${entry.id} 每日简报：${stats.articles_processed ?? 0} 条 · ${topics.length} 主题`}
>
  <DailyPageContent entry={entry} />
</BaseLayout>
