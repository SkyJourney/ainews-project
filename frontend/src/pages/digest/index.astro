---
// AInews · Digest 列表（M6 新增，旧前端从未消费过这类文档）
// Digest 定位"可独立分享打印"，不含 wikilink，结构比 Daily 简单很多
// Stage 2/3：改走轻量分页查询
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import IntelligenceCard from '../../components/cards/IntelligenceCard.astro'
import { fetchDocumentSummariesByType } from '../../lib/db'
import { DIGEST_PAGE_SIZE } from '../../lib/pagination'

const { rows, total } = await fetchDocumentSummariesByType('digest', { limit: DIGEST_PAGE_SIZE, offset: 0 })
const eyebrow = `${total} 期`
const hasMore = rows.length < total
---

<BaseLayout title="Digest · 摘要速览" description="AInews 摘要速览 · 事实性条目，适合独立分享">
  <HeroSection
    eyebrow={eyebrow}
    title="摘要速览"
    subtitle="每条 2-3 句话的事实性摘要，来源标识与原文链接齐全，适合独立分享或打印"
  />

  <div class="digest-list" data-infinite-list data-endpoint="/digest/more" data-page="2" data-mode="flat">
    {rows.map((row) => {
      const dateLabel = row.id.replace(/^digest-/, '')
      const entryCount = (row.frontmatter.entry_count as number | null) ?? 0
      return (
        <IntelligenceCard
          href={`/digest/${row.id}/`}
          eyebrow={dateLabel}
          title={`AI Digest ${dateLabel}`}
          summary={`共 ${entryCount} 条`}
          metaLine=""
          ai={false}
        />
      )
    })}
    {hasMore && <div data-scroll-sentinel></div>}
  </div>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .digest-list {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }
</style>
