---
// AInews · Digest 滑动懒加载片段端点
export const prerender = false

import IntelligenceCard from '../../components/cards/IntelligenceCard.astro'
import { fetchDocumentSummariesByType } from '../../lib/db'
import { DIGEST_PAGE_SIZE } from '../../lib/pagination'

const pageParam = Number(Astro.url.searchParams.get('page') ?? '2')
const page = Number.isFinite(pageParam) && pageParam >= 1 ? pageParam : 2
const offset = (page - 1) * DIGEST_PAGE_SIZE

const { rows, total } = await fetchDocumentSummariesByType('digest', { limit: DIGEST_PAGE_SIZE, offset })
const hasMore = offset + rows.length < total
Astro.response.headers.set('X-Has-More', String(hasMore))
Astro.response.headers.set('Cache-Control', 'no-store')
---

<div data-fragment>
  {rows.map((row) => {
    const dateLabel = row.id.replace(/^digest-/, '')
    const entryCount = (row.frontmatter.entry_count as number | null) ?? 0
    return (
      <IntelligenceCard
        href={`/digest/${row.id}/`}
        eyebrow={dateLabel}
        title={`AI Digest ${dateLabel}`}
        summary={`共 ${entryCount} 条`}
        metaLine=""
        ai={false}
      />
    )
  })}
</div>
