---
// AInews · Zettel 列表 · 2-col masonry（用 CSS columns 实现）
// Stage 2/3：改走轻量分页查询，不再经过 postgres-loader.ts 的全文渲染+逐条查
// backlinks/tags；backlink 数量改成批量查询一次
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/cards/HeroSection.astro'
import ZettelCard from '../../components/cards/ZettelCard.astro'
import { fetchDocumentSummariesByType, fetchBacklinkCounts, fetchDistinctFrontmatterFieldCount } from '../../lib/db'
import { ZETTEL_PAGE_SIZE } from '../../lib/pagination'

const [{ rows, total }, topicCount] = await Promise.all([
  fetchDocumentSummariesByType('zettel', { limit: ZETTEL_PAGE_SIZE, offset: 0 }),
  fetchDistinctFrontmatterFieldCount('zettel', 'topic_slug'),
])
const backlinkCounts = await fetchBacklinkCounts(rows.map((r) => r.id))
const eyebrow = `${total} 张 · ${topicCount} 主题`
const hasMore = rows.length < total
---

<BaseLayout
  title="Zettel · 原子卡片"
  description="AInews 原子知识卡片 · 一题一卡 · 4 段式结构"
>
  <HeroSection
    eyebrow={eyebrow}
    title="原子卡片"
    subtitle="每张卡片聚焦一个核心概念，点开关联标签，串起完整的知识脉络"
  />

  <div class="zettel-masonry" data-infinite-list data-endpoint="/zettel/more" data-page="2" data-mode="flat">
    {rows.map((row) => (
      <ZettelCard
        id={row.id}
        title={row.title}
        gist={(row.frontmatter.gist as string | null) ?? null}
        topicSlug={(row.frontmatter.topic_slug as string | null) ?? null}
        docDate={row.doc_date}
        backlinkCount={backlinkCounts.get(row.id) ?? 0}
      />
    ))}
    {hasMore && <div data-scroll-sentinel></div>}
  </div>
</BaseLayout>

<script is:inline src="/infinite-scroll.js"></script>

<style>
  .zettel-masonry {
    columns: 2;
    column-gap: 1rem;
    margin-top: 2rem;
  }
  @media (max-width: 640px) {
    .zettel-masonry { columns: 1; }
  }
</style>
